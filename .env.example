# Runtime
NODE_ENV=development
PORT=5000

# Database
MONGO_URI=mongodb://localhost:27017/zorvyn

# Auth
JWT_SECRET=replace-with-a-long-random-string-at-least-32-characters
JWT_EXPIRES_IN=1d

# Security
# Comma-separated list. In development, all origins are allowed.
CORS_ORIGIN=http://localhost:3000

# Seed safety guard (required for npm run seed)
ALLOW_SEED_RESET=false
